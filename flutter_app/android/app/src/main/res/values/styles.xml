<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Activity as soon as the process has started.
         This theme is replaced by "NormalTheme" once the Flutter UI is ready -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <!-- Show a splash image unless you prefer to use the NormalTheme -->
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <!-- Theme to apply after the launch screen is completed -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
